generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  nameAr        String
  nameEn        String?
  role          String   @default("teacher") // teacher, student, supervisor, educational_reviewer, quranic_reviewer, researcher, admin
  institutionId String?
  avatarUrl     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution  Institution?       @relation(fields: [institutionId], references: [id])
  classes      ClassTeacher[]
  activities   Activity[]
  observations BehavioralObservation[]
  reviews      ContentReview[]
  auditLogs    AuditLog[]
  createdTechniques Technique[]
}

model Institution {
  id          String   @id @default(cuid())
  nameAr      String
  nameEn      String?
  type        String   @default("school")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  classes     ClassRoom[]
}

model ClassRoom {
  id              String   @id @default(cuid())
  nameAr          String
  nameEn          String?
  educationalLevel String   // primary, middle, secondary, university
  grade           String?
  academicYear    String?
  institutionId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  institution Institution?       @relation(fields: [institutionId], references: [id])
  teachers     ClassTeacher[]
  students     Student[]
  activities   Activity[]
}

model ClassTeacher {
  id        String   @id @default(cuid())
  userId    String
  classId   String
  role      String   @default("teacher")
  createdAt DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id])
  class ClassRoom @relation(fields: [classId], references: [id])

  @@unique([userId, classId])
}

model Student {
  id            String   @id @default(cuid())
  identifier    String   // Privacy-safe identifier (not real name)
  classId       String
  dateOfBirth   DateTime?
  gender        String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  class        ClassRoom              @relation(fields: [classId], references: [id])
  observations BehavioralObservation[]
  reflections  StudentReflection[]
  progress     StudentProgress[]
}

model MoralValue {
  id          String   @id @default(cuid())
  nameAr      String
  nameEn      String
  descriptionAr String
  descriptionEn String?
  icon        String?
  color       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  behaviors     TargetBehavior[]
  techniques    Technique[]
  progressions  ValueProgression[]
}

model TargetBehavior {
  id          String   @id @default(cuid())
  nameAr      String
  nameEn      String?
  descriptionAr String
  descriptionEn String?
  valueId     String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  value      MoralValue @relation(fields: [valueId], references: [id])
  techniques Technique[]
}

model Technique {
  id                    String   @id @default(cuid())
  titleAr               String
  titleEn               String?
  descriptionAr         String
  descriptionEn         String?
  educationalLevel      String   // primary, middle, secondary, university
  subjects              String   // JSON array of subject names
  topic                 String?
  behaviorId            String?
  valueId               String?
  activityType          String   // story, roleplay, experiment, competition, project, debate, case_study, community_service, reflection, simulation, group_problem
  durationMinutes       Int
  groupSize             String?  // individual, pairs, small_groups, whole_class
  location              String?  // classroom, laboratory, sports, library, university, community
  difficulty            String   @default("medium") // easy, medium, advanced

  academicObjectiveAr     String?
  academicObjectiveEn     String?
  behavioralObjectiveAr   String?
  behavioralObjectiveEn   String?
  quranicFoundation       String? // JSON: {reference, chapter, verse, summary}
  foundationRelationshipAr String?
  foundationRelationshipEn String?
  implementationStepsAr   String // JSON array
  implementationStepsEn   String?
  teacherRoleAr          String?
  teacherRoleEn          String?
  studentRoleAr          String?
  studentRoleEn          String?
  requiredResourcesAr    String? // JSON array
  requiredResourcesEn    String?
  reflectionQuestionsAr  String // JSON array
  reflectionQuestionsEn  String?
  observationIndicatorsAr String // JSON array
  observationIndicatorsEn String?
  progressLevelsAr       String? // JSON array
  progressLevelsEn       String?
  differentiationAr      String? // JSON array
  differentiationEn      String?
  educationalRisksAr     String? // JSON array
  educationalRisksEn     String?
  safeguardsAr           String? // JSON array
  safeguardsEn           String?
  dailyLifeTransferAr    String?
  dailyLifeTransferEn    String?
  followUpRecommendationAr String?
  followUpRecommendationEn String?

  reviewStatus          String   @default("draft") // draft, educational_review, quranic_review, approved, revision_required, rejected
  isAIGenerated         Boolean  @default(true)
  isFeatured            Boolean  @default(false)
  createdById           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  behavior  TargetBehavior?    @relation(fields: [behaviorId], references: [id])
  value     MoralValue?        @relation(fields: [valueId], references: [id])
  createdBy User?              @relation(fields: [createdById], references: [id])
  reviews   ContentReview[]
  activities Activity[]
}

model ValueProgression {
  id              String   @id @default(cuid())
  valueId         String
  educationalLevel String
  focusAr         String
  focusEn         String?
  formatsAr       String // JSON array
  formatsEn       String?
  observableBehaviorAr String
  observableBehaviorEn String?
  sortOrder       Int      @default(0)

  value MoralValue @relation(fields: [valueId], references: [id])

  @@unique([valueId, educationalLevel])
}

model Activity {
  id              String   @id @default(cuid())
  titleAr         String
  titleEn         String?
  classId         String?
  techniqueId     String?
  teacherId       String?
  status          String   @default("draft") // draft, assigned, in_progress, completed
  scheduledDate   DateTime?
  completedDate   DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  class     ClassRoom?           @relation(fields: [classId], references: [id])
  technique Technique?           @relation(fields: [techniqueId], references: [id])
  teacher   User?                @relation(fields: [teacherId], references: [id])
  observations BehavioralObservation[]
  reflections StudentReflection[]
}

model BehavioralObservation {
  id            String   @id @default(cuid())
  activityId    String?
  studentId     String
  observerId    String?
  behaviorNote  String   // Situation-specific, not labels
  indicatorNote String?
  progressLevel String?  // emerging, developing, practicing, consistent, transferring
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  activity Activity? @relation(fields: [activityId], references: [id])
  student  Student    @relation(fields: [studentId], references: [id])
  observer User?      @relation(fields: [observerId], references: [id])
}

model StudentReflection {
  id            String   @id @default(cuid())
  studentId     String
  activityId    String?
  promptAr      String?
  promptEn      String?
  responseAr    String?
  responseEn    String?
  isPrivate     Boolean  @default(true)
  goalText      String?  // Personal improvement goal
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student  Student    @relation(fields: [studentId], references: [id])
  activity Activity? @relation(fields: [activityId], references: [id])
}

model StudentProgress {
  id            String   @id @default(cuid())
  studentId     String
  valueId       String?
  level         String   // emerging, developing, practicing, consistent, transferring
  notes         String?
  periodStart   DateTime
  periodEnd     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student Student    @relation(fields: [studentId], references: [id])
}

model ContentReview {
  id          String   @id @default(cuid())
  techniqueId String?
  reviewerId  String
  reviewType  String   // educational, quranic
  status      String   @default("pending") // pending, approved, revision_required, rejected
  comments    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  technique Technique? @relation(fields: [techniqueId], references: [id])
  reviewer  User       @relation(fields: [reviewerId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  details   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
